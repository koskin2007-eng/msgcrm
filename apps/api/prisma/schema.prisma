generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChannelType {
  AVITO
  TELEGRAM
}

enum ConversationStatus {
  NEW
  OPEN
  WAITING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageAuthorType {
  CUSTOMER
  MANAGER
  AI
  SYSTEM
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  VIEWER
}

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  channelAccounts    ChannelAccount[]
  customers          Customer[]
  listings           Listing[]
  conversations      Conversation[]
  knowledgeDocuments KnowledgeDocument[]
}

model User {
  id           String   @id @default(uuid())
  companyId    String?
  email        String   @unique
  displayName  String
  phone        String?
  role         UserRole @default(MANAGER)
  isActive     Boolean  @default(true)
  passwordHash String?
  inviteTokenHash String? @unique
  inviteExpiresAt DateTime?
  invitedAt DateTime?
  acceptedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company               Company?       @relation(fields: [companyId], references: [id])
  sessions              Session[]
  assignedConversations Conversation[] @relation("ConversationAssignee")

  @@index([companyId])
  @@index([inviteExpiresAt])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ChannelAccount {
  id           String      @id @default(uuid())
  companyId    String?
  type         ChannelType
  displayName  String
  externalId   String
  accessToken  String?
  refreshToken String?
  tokenExpiresAt DateTime?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company       Company?       @relation(fields: [companyId], references: [id])
  conversations Conversation[]
  listings      Listing[]

  @@index([companyId])
  @@unique([type, externalId])
}

model Customer {
  id          String   @id @default(uuid())
  companyId   String?
  displayName String?
  externalId  String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company?       @relation(fields: [companyId], references: [id])
  conversations Conversation[]

  @@index([companyId])
}

model Listing {
  id               String   @id @default(uuid())
  companyId        String?
  channelAccountId String
  externalId       String
  title            String
  url              String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company        Company?       @relation(fields: [companyId], references: [id])
  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id])
  conversations  Conversation[]

  @@index([companyId])
  @@unique([channelAccountId, externalId])
}

model Conversation {
  id               String             @id @default(uuid())
  companyId        String?
  channelAccountId String
  customerId       String?
  listingId        String?
  assigneeId       String?
  externalId       String
  status           ConversationStatus @default(NEW)
  lastMessageAt    DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  company        Company?       @relation(fields: [companyId], references: [id])
  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id])
  customer       Customer?      @relation(fields: [customerId], references: [id])
  listing        Listing?       @relation(fields: [listingId], references: [id])
  assignee       User?          @relation("ConversationAssignee", fields: [assigneeId], references: [id])
  messages       Message[]

  @@unique([channelAccountId, externalId])
  @@index([companyId])
  @@index([status, lastMessageAt])
}

model Message {
  id             String            @id @default(uuid())
  conversationId String
  externalId     String?
  direction      MessageDirection
  authorType     MessageAuthorType
  text           String
  sentAt         DateTime
  createdAt      DateTime          @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, externalId])
  @@index([conversationId, sentAt])
}

model KnowledgeDocument {
  id        String   @id @default(uuid())
  companyId String?
  title     String
  source    String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company?         @relation(fields: [companyId], references: [id])
  chunks  KnowledgeChunk[]

  @@index([companyId])
}

model KnowledgeChunk {
  id         String @id @default(uuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  createdAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id])
}
